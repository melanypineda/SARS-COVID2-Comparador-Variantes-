def comparar_secuencias(seq_original, seq_final):
    # Verificamos que tengan la misma longitud para comparar posición por posición
    if len(seq_original) != len(seq_final):
        return "Error: Las secuencias tienen longitudes distintas."

    mutaciones = []

    # Recorremos la secuencia usando el índice
    for i in range(len(seq_original)):
        nucleotido_orig = seq_original[i]
        nucleotido_final = seq_final[i]

        # Si son diferentes, guardamos la posición y el cambio
        if nucleotido_orig != nucleotido_final:
            # i + 1 para que la posición sea legible para humanos (no empiece en 0)
            cambio = f"Posición {i+1}: {nucleotido_orig} -> {nucleotido_final}"
            mutaciones.append(cambio)

    return mutaciones

# Datos de prueba (Fragmentos de ARN: Adenina, Uracilo, Citocina, Guanina)
secuencia_inicial = "AUGCCGUAACGUA"
secuencia_pase_10 = "AUGCCGUAAGGUA" # Cambiamos la 'C' por una 'G' en la posición 10

resultados = comparar_secuencias(secuencia_inicial, secuencia_pase_10)

print("--- Informe de Mutaciones Detectadas ---")
if resultados:
    for m in resultados:
        print(m)
else:
    print("No se detectaron cambios en la secuencia.")
